{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "bracketSpacing": true,
    "printWidth": 120,
    "proseWrap": "preserve",
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "tabWidth": 4,
    "useTabs": false,
    "arrowParens": "always",
    "endOfLine": "lf",
    "overrides": [
        {
            "files": ["*.json"],
            "options": {
                "singleQuote": false
            }
        }
    ]
}
